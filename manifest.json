{
  "manifest_version": 3,
  "name": "Slack Thread Copy Fix",
  "version": "1.0",
  "description": "Adds 'Copy text' to Slack thread messages",
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["https://app.slack.com/*", "https://*.slack.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
